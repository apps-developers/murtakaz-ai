# Copy to .env and adjust values as needed.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=kpi
POSTGRES_PORT=5432

# Prisma / app connection string
DATABASE_URL=postgresql://postgres@localhost:5432/kpi?schema=public

# Better Auth
BETTER_AUTH_SECRET=changeme_in_production_random_string_123
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000


NEXT_PUBLIC_AI_ENABLED=true   # show all AI UI
# NEXT_PUBLIC_AI_ENABLED=false  # hide everything — no AI elements rendered